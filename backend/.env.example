# 环境变量示例
# 复制此文件为 .env 并填入实际值

# LLM API (DeepSeek 配置)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-reasoner

# Stockfish 引擎路径
# 请将下载好的 stockfish.exe 放在此路径下
STOCKFISH_PATH=engines/stockfish.exe

# 数据库
DATABASE_URL=sqlite:///./chess_explain.db

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 开发模式
DEBUG=true